<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Twitter24 — Discover What's Around You</title>

  <!-- Google Fonts -->
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&family=Poppins:wght@400;600;700;800&display=swap" rel="stylesheet" />

  <!-- Bootstrap 5 -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />

  <!-- Bootstrap Icons -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />

  <style>
    :root {
      --primary: #1d9bf0;
      --primary-dark: #0d8ae0;
      --secondary: #0f1419;
      --accent: #ffd700;
      --surface: #16181c;
      --surface2: #1e2128;
      --border: #2f3336;
      --text-muted: #71767b;
      --text-light: #e7e9ea;
      --gradient-1: linear-gradient(135deg, #1d9bf0 0%, #6c47ff 100%);
      --gradient-2: linear-gradient(135deg, #ff6b6b 0%, #ffd700 100%);
      --gradient-3: linear-gradient(135deg, #00c9a7 0%, #1d9bf0 100%);
    }

    * { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      font-family: 'Inter', sans-serif;
      background-color: #0a0c0f;
      color: var(--text-light);
      overflow-x: hidden;
    }

    /* ── NAVBAR ── */
    .navbar {
      background: rgba(10, 12, 15, 0.85);
      backdrop-filter: blur(20px);
      border-bottom: 1px solid var(--border);
      padding: 14px 0;
      position: sticky;
      top: 0;
      z-index: 1000;
    }

    .navbar-brand {
      font-family: 'Poppins', sans-serif;
      font-weight: 800;
      font-size: 1.5rem;
      color: var(--primary) !important;
      letter-spacing: -0.5px;
      display: flex;
      align-items: center;
      gap: 8px;
    }

    .navbar-brand .logo-icon {
      width: 36px;
      height: 36px;
      background: var(--gradient-1);
      border-radius: 10px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 1.1rem;
      color: #fff;
    }

    .nav-link {
      color: var(--text-light) !important;
      font-weight: 500;
      font-size: 0.95rem;
      padding: 6px 14px !important;
      border-radius: 8px;
      transition: all 0.2s;
    }

    .nav-link:hover { background: var(--surface2); color: var(--primary) !important; }

    .btn-nav-signin {
      background: transparent;
      border: 1.5px solid var(--primary);
      color: var(--primary) !important;
      font-weight: 600;
      border-radius: 999px;
      padding: 7px 22px !important;
      transition: all 0.2s;
    }

    .btn-nav-signin:hover { background: var(--primary); color: #fff !important; }

    .btn-nav-signup {
      background: var(--primary);
      border: none;
      color: #fff !important;
      font-weight: 600;
      border-radius: 999px;
      padding: 7px 22px !important;
      transition: all 0.2s;
    }

    .btn-nav-signup:hover { background: var(--primary-dark); }

    /* ── HERO ── */
    .hero {
      min-height: 92vh;
      display: flex;
      align-items: center;
      position: relative;
      overflow: hidden;
      padding: 80px 0;
    }

    .hero::before {
      content: '';
      position: absolute;
      inset: 0;
      background:
        radial-gradient(ellipse 80% 60% at 70% 40%, rgba(29, 155, 240, 0.12) 0%, transparent 60%),
        radial-gradient(ellipse 50% 40% at 10% 80%, rgba(108, 71, 255, 0.10) 0%, transparent 60%);
      pointer-events: none;
    }

    .hero-badge {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      background: rgba(29, 155, 240, 0.12);
      border: 1px solid rgba(29, 155, 240, 0.3);
      color: var(--primary);
      font-size: 0.82rem;
      font-weight: 600;
      padding: 6px 16px;
      border-radius: 999px;
      margin-bottom: 24px;
      letter-spacing: 0.3px;
    }

    .hero-title {
      font-family: 'Poppins', sans-serif;
      font-size: clamp(2.5rem, 6vw, 4.5rem);
      font-weight: 800;
      line-height: 1.1;
      letter-spacing: -1.5px;
      margin-bottom: 24px;
    }

    .hero-title .highlight {
      background: var(--gradient-1);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }

    .hero-subtitle {
      font-size: 1.15rem;
      color: var(--text-muted);
      line-height: 1.7;
      max-width: 520px;
      margin-bottom: 40px;
      font-weight: 400;
    }

    .hero-actions { display: flex; gap: 14px; flex-wrap: wrap; }

    .btn-primary-hero {
      background: var(--gradient-1);
      border: none;
      color: #fff;
      font-weight: 700;
      font-size: 1rem;
      padding: 14px 32px;
      border-radius: 999px;
      transition: all 0.3s;
      box-shadow: 0 8px 30px rgba(29, 155, 240, 0.35);
      text-decoration: none;
    }

    .btn-primary-hero:hover {
      transform: translateY(-2px);
      box-shadow: 0 12px 40px rgba(29, 155, 240, 0.5);
      color: #fff;
    }

    .btn-outline-hero {
      background: transparent;
      border: 1.5px solid var(--border);
      color: var(--text-light);
      font-weight: 600;
      font-size: 1rem;
      padding: 14px 32px;
      border-radius: 999px;
      transition: all 0.3s;
      text-decoration: none;
    }

    .btn-outline-hero:hover {
      border-color: var(--primary);
      color: var(--primary);
      transform: translateY(-2px);
    }

    .hero-stats {
      display: flex;
      gap: 40px;
      margin-top: 56px;
      padding-top: 40px;
      border-top: 1px solid var(--border);
    }

    .hero-stat-number {
      font-family: 'Poppins', sans-serif;
      font-size: 2rem;
      font-weight: 800;
      background: var(--gradient-1);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
      line-height: 1;
    }

    .hero-stat-label {
      font-size: 0.82rem;
      color: var(--text-muted);
      margin-top: 4px;
      font-weight: 500;
    }

    /* ── HERO VISUAL ── */
    .hero-visual {
      position: relative;
      height: 560px;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .phone-mockup {
      width: 280px;
      background: var(--surface);
      border-radius: 40px;
      border: 2px solid var(--border);
      overflow: hidden;
      box-shadow: 0 40px 100px rgba(0, 0, 0, 0.6), 0 0 0 1px rgba(255,255,255,0.04);
      position: relative;
      z-index: 2;
    }

    .phone-notch {
      height: 32px;
      background: var(--secondary);
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .phone-notch-bar {
      width: 80px;
      height: 6px;
      background: var(--border);
      border-radius: 999px;
    }

    .phone-screen {
      padding: 16px;
      min-height: 480px;
      background: var(--surface);
    }

    .phone-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-bottom: 16px;
    }

    .phone-logo {
      font-family: 'Poppins', sans-serif;
      font-weight: 800;
      font-size: 1.1rem;
      color: var(--primary);
    }

    .phone-avatar {
      width: 32px;
      height: 32px;
      border-radius: 50%;
      background: var(--gradient-1);
    }

    .feed-card {
      background: var(--surface2);
      border: 1px solid var(--border);
      border-radius: 14px;
      padding: 12px;
      margin-bottom: 10px;
    }

    .feed-card-header {
      display: flex;
      align-items: center;
      gap: 8px;
      margin-bottom: 8px;
    }

    .feed-avatar {
      width: 28px;
      height: 28px;
      border-radius: 50%;
      flex-shrink: 0;
    }

    .feed-name {
      font-size: 0.72rem;
      font-weight: 600;
      color: var(--text-light);
    }

    .feed-time {
      font-size: 0.62rem;
      color: var(--text-muted);
    }

    .feed-text {
      font-size: 0.72rem;
      color: var(--text-muted);
      line-height: 1.5;
      margin-bottom: 8px;
    }

    .feed-image-placeholder {
      height: 60px;
      border-radius: 8px;
      margin-bottom: 8px;
    }

    .feed-actions {
      display: flex;
      gap: 12px;
    }

    .feed-action {
      font-size: 0.62rem;
      color: var(--text-muted);
      display: flex;
      align-items: center;
      gap: 3px;
    }

    .badge-local {
      font-size: 0.55rem;
      background: rgba(0, 201, 167, 0.15);
      color: #00c9a7;
      border: 1px solid rgba(0, 201, 167, 0.3);
      padding: 2px 7px;
      border-radius: 999px;
      font-weight: 600;
    }

    .badge-global {
      font-size: 0.55rem;
      background: rgba(29, 155, 240, 0.15);
      color: var(--primary);
      border: 1px solid rgba(29, 155, 240, 0.3);
      padding: 2px 7px;
      border-radius: 999px;
      font-weight: 600;
    }

    /* Floating cards around phone */
    .float-card {
      position: absolute;
      background: var(--surface2);
      border: 1px solid var(--border);
      border-radius: 16px;
      padding: 12px 16px;
      box-shadow: 0 20px 60px rgba(0,0,0,0.4);
      z-index: 3;
    }

    .float-card-1 {
      top: 60px;
      right: 0;
      width: 170px;
    }

    .float-card-2 {
      bottom: 100px;
      left: -10px;
      width: 160px;
    }

    .float-card-3 {
      top: 200px;
      left: -20px;
      width: 145px;
    }

    .float-card-title {
      font-size: 0.7rem;
      color: var(--text-muted);
      margin-bottom: 4px;
    }

    .float-card-value {
      font-family: 'Poppins', sans-serif;
      font-size: 1.2rem;
      font-weight: 700;
      color: var(--text-light);
    }

    .float-card-icon {
      width: 32px;
      height: 32px;
      border-radius: 8px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 1rem;
      margin-bottom: 8px;
    }

    /* Glow circles */
    .glow-circle {
      position: absolute;
      border-radius: 50%;
      filter: blur(80px);
      opacity: 0.15;
      pointer-events: none;
    }

    .glow-1 { width: 400px; height: 400px; background: var(--primary); top: -100px; right: -100px; }
    .glow-2 { width: 300px; height: 300px; background: #6c47ff; bottom: -50px; left: -50px; }

    /* ── FEATURES ── */
    .section-label {
      font-size: 0.8rem;
      font-weight: 700;
      letter-spacing: 2px;
      text-transform: uppercase;
      color: var(--primary);
      margin-bottom: 14px;
    }

    .section-title {
      font-family: 'Poppins', sans-serif;
      font-size: clamp(1.8rem, 4vw, 2.8rem);
      font-weight: 800;
      line-height: 1.2;
      letter-spacing: -0.5px;
      margin-bottom: 16px;
    }

    .section-desc {
      font-size: 1.05rem;
      color: var(--text-muted);
      line-height: 1.7;
      max-width: 560px;
    }

    .features-section {
      padding: 100px 0;
      background: linear-gradient(180deg, #0a0c0f 0%, #0d1117 100%);
    }

    .feature-card {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 20px;
      padding: 32px;
      height: 100%;
      transition: all 0.3s;
      position: relative;
      overflow: hidden;
    }

    .feature-card::before {
      content: '';
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      height: 2px;
      opacity: 0;
      transition: opacity 0.3s;
    }

    .feature-card:hover { transform: translateY(-6px); border-color: rgba(29, 155, 240, 0.3); }
    .feature-card:hover::before { opacity: 1; }

    .fc-blue::before { background: var(--gradient-1); }
    .fc-green::before { background: var(--gradient-3); }
    .fc-orange::before { background: var(--gradient-2); }
    .fc-purple::before { background: linear-gradient(135deg, #6c47ff, #1d9bf0); }

    .feature-icon {
      width: 56px;
      height: 56px;
      border-radius: 16px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 1.5rem;
      margin-bottom: 20px;
    }

    .fi-blue { background: rgba(29, 155, 240, 0.15); color: var(--primary); }
    .fi-green { background: rgba(0, 201, 167, 0.15); color: #00c9a7; }
    .fi-orange { background: rgba(255, 107, 107, 0.15); color: #ff6b6b; }
    .fi-purple { background: rgba(108, 71, 255, 0.15); color: #6c47ff; }
    .fi-yellow { background: rgba(255, 215, 0, 0.15); color: #ffd700; }
    .fi-pink { background: rgba(255, 107, 156, 0.15); color: #ff6b9d; }

    .feature-title {
      font-family: 'Poppins', sans-serif;
      font-size: 1.2rem;
      font-weight: 700;
      margin-bottom: 10px;
      color: var(--text-light);
    }

    .feature-desc {
      font-size: 0.92rem;
      color: var(--text-muted);
      line-height: 1.65;
    }

    /* ── HOW IT WORKS ── */
    .how-section {
      padding: 100px 0;
      background: #0a0c0f;
    }

    .step-number {
      width: 48px;
      height: 48px;
      background: var(--gradient-1);
      border-radius: 14px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-family: 'Poppins', sans-serif;
      font-weight: 800;
      font-size: 1.1rem;
      color: #fff;
      flex-shrink: 0;
    }

    .step-connector {
      width: 2px;
      flex: 1;
      background: linear-gradient(180deg, var(--primary) 0%, transparent 100%);
      margin: 8px auto;
      min-height: 40px;
    }

    .step-content { padding-left: 20px; }

    .step-title {
      font-family: 'Poppins', sans-serif;
      font-weight: 700;
      font-size: 1.1rem;
      margin-bottom: 6px;
    }

    .step-desc {
      font-size: 0.9rem;
      color: var(--text-muted);
      line-height: 1.6;
    }

    /* ── BUSINESS SECTION ── */
    .business-section {
      padding: 100px 0;
      background: linear-gradient(180deg, #0d1117 0%, #0a0c0f 100%);
      position: relative;
      overflow: hidden;
    }

    .business-section::before {
      content: '';
      position: absolute;
      inset: 0;
      background: radial-gradient(ellipse 60% 50% at 50% 50%, rgba(29, 155, 240, 0.06) 0%, transparent 70%);
    }

    .biz-card {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 20px;
      padding: 24px;
      display: flex;
      align-items: center;
      gap: 16px;
      transition: all 0.3s;
      margin-bottom: 16px;
    }

    .biz-card:hover { border-color: rgba(29, 155, 240, 0.3); transform: translateX(6px); }

    .biz-avatar {
      width: 52px;
      height: 52px;
      border-radius: 14px;
      flex-shrink: 0;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 1.5rem;
    }

    .biz-name {
      font-weight: 700;
      font-size: 0.95rem;
      color: var(--text-light);
      margin-bottom: 2px;
    }

    .biz-category {
      font-size: 0.78rem;
      color: var(--text-muted);
    }

    .biz-rating {
      margin-left: auto;
      display: flex;
      align-items: center;
      gap: 4px;
      font-size: 0.8rem;
      font-weight: 600;
      color: #ffd700;
    }

    .biz-distance {
      font-size: 0.72rem;
      color: var(--text-muted);
      text-align: right;
    }

    /* ── API ENDPOINTS ── */
    .api-section {
      padding: 100px 0;
      background: #0a0c0f;
    }

    .endpoint-item {
      display: flex;
      align-items: center;
      gap: 14px;
      padding: 14px 20px;
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 12px;
      margin-bottom: 10px;
      transition: all 0.2s;
    }

    .endpoint-item:hover { border-color: rgba(29,155,240,0.3); }

    .method-badge {
      font-size: 0.7rem;
      font-weight: 700;
      padding: 4px 10px;
      border-radius: 6px;
      font-family: 'Poppins', sans-serif;
      min-width: 52px;
      text-align: center;
    }

    .method-get { background: rgba(0, 201, 167, 0.15); color: #00c9a7; }
    .method-post { background: rgba(29, 155, 240, 0.15); color: var(--primary); }
    .method-put { background: rgba(255, 215, 0, 0.15); color: #ffd700; }
    .method-delete { background: rgba(255, 107, 107, 0.15); color: #ff6b6b; }

    .endpoint-path {
      font-family: 'Courier New', monospace;
      font-size: 0.85rem;
      color: var(--text-light);
      flex: 1;
    }

    .endpoint-desc {
      font-size: 0.8rem;
      color: var(--text-muted);
    }

    /* ── CTA ── */
    .cta-section {
      padding: 120px 0;
      background: linear-gradient(135deg, #0d1117 0%, #0a0c0f 100%);
      position: relative;
      overflow: hidden;
    }

    .cta-section::before {
      content: '';
      position: absolute;
      inset: 0;
      background: radial-gradient(ellipse 80% 60% at 50% 50%, rgba(29, 155, 240, 0.1) 0%, transparent 70%);
    }

    .cta-title {
      font-family: 'Poppins', sans-serif;
      font-size: clamp(2rem, 5vw, 3.5rem);
      font-weight: 800;
      line-height: 1.15;
      letter-spacing: -0.5px;
      margin-bottom: 20px;
    }

    .cta-desc {
      font-size: 1.1rem;
      color: var(--text-muted);
      max-width: 480px;
      margin: 0 auto 40px;
      line-height: 1.7;
    }

    /* ── FOOTER ── */
    footer {
      background: var(--surface);
      border-top: 1px solid var(--border);
      padding: 60px 0 32px;
    }

    .footer-brand {
      font-family: 'Poppins', sans-serif;
      font-weight: 800;
      font-size: 1.4rem;
      color: var(--primary);
      margin-bottom: 12px;
    }

    .footer-desc {
      font-size: 0.88rem;
      color: var(--text-muted);
      line-height: 1.6;
      max-width: 260px;
    }

    .footer-heading {
      font-weight: 700;
      font-size: 0.88rem;
      color: var(--text-light);
      margin-bottom: 16px;
      letter-spacing: 0.5px;
    }

    .footer-link {
      display: block;
      font-size: 0.85rem;
      color: var(--text-muted);
      text-decoration: none;
      margin-bottom: 10px;
      transition: color 0.2s;
    }

    .footer-link:hover { color: var(--primary); }

    .footer-divider {
      border-color: var(--border);
      margin: 40px 0 24px;
    }

    .footer-copy {
      font-size: 0.82rem;
      color: var(--text-muted);
    }

    /* ── SCROLL ANIMATIONS ── */
    .fade-up {
      opacity: 0;
      transform: translateY(30px);
      transition: opacity 0.6s ease, transform 0.6s ease;
    }

    .fade-up.visible {
      opacity: 1;
      transform: translateY(0);
    }

    /* ── DIVIDER ── */
    .gradient-divider {
      height: 1px;
      background: linear-gradient(90deg, transparent, var(--border), transparent);
    }

    /* ── PILL TAGS ── */
    .pill {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      padding: 6px 14px;
      border-radius: 999px;
      font-size: 0.8rem;
      font-weight: 600;
      margin: 4px;
    }

    .pill-blue { background: rgba(29,155,240,0.12); color: var(--primary); border: 1px solid rgba(29,155,240,0.2); }
    .pill-green { background: rgba(0,201,167,0.12); color: #00c9a7; border: 1px solid rgba(0,201,167,0.2); }
    .pill-purple { background: rgba(108,71,255,0.12); color: #6c47ff; border: 1px solid rgba(108,71,255,0.2); }
    .pill-yellow { background: rgba(255,215,0,0.12); color: #ffd700; border: 1px solid rgba(255,215,0,0.2); }
    .pill-red { background: rgba(255,107,107,0.12); color: #ff6b6b; border: 1px solid rgba(255,107,107,0.2); }
  </style>
</head>
<body>

